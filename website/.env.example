# Altfragen admin (required for /altfragen/admin — no default password)
ALTFRAGEN_ADMIN_PASSWORD=change-me-strong

# Fachschaft access code (recommended before sharing Kreuzen)
ALTFRAGEN_ACCESS_CODE=change-me-fachschaft

# Soft entry gate (optional). When set, site requires Referer from these origins
# (or entry cookie / admin bypass). Leave unset for open local/dev access.
# ENTRY_GATE_ORIGINS=https://www.altklausurendb.de,https://altklausurendb.de
# Admin bookmark bypass: https://adalbert.vercel.app/?gate=<secret>
# ENTRY_GATE_BYPASS_SECRET=change-me-long-random

# Optional: persist exam bank / stats on Vercel via GitHub Contents API
# ALTFRAGEN_GITHUB_TOKEN=
# ALTFRAGEN_GITHUB_REPO=ferdinandschweigert/adalbert
# ALTFRAGEN_GITHUB_PATH=website/data/altfragen-bank.json
# ALTFRAGEN_GITHUB_BRANCH=main

# LLM (needed for PDF/text conversion — local Anki + admin convert)
# GEMINI_API_KEY=
# LLM_PROVIDER=gemini
